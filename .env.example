# Copy to .env and adjust as needed.
# Most defaults in config.py are fine for local development.

# ── Data ──────────────────────────────────────────────────────────────
DATA_PATH=data/sample_data.csv

# ── Strategy defaults ─────────────────────────────────────────────────
SMA_SHORT_WINDOW=20
SMA_LONG_WINDOW=50
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
RSI_WINDOW=14
RSI_OVERSOLD=30.0
RSI_OVERBOUGHT=70.0

# ── Risk / sizing ─────────────────────────────────────────────────────
TRANSACTION_COST_BPS=5.0    # one-way, in basis points
MAX_POSITION_SIZE=1.0       # fraction of portfolio (1.0 = 100%)

# ── Calendar ──────────────────────────────────────────────────────────
TRADING_DAYS_PER_YEAR=252   # used for annualisation

# ── Infrastructure ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Misc ──────────────────────────────────────────────────────────────
RISK_FREE_RATE_ANNUAL=0.04  # 4% annual risk-free rate
