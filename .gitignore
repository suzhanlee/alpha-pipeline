# ── 가상환경 / 패키지 매니저 ─────────────────────────────
.venv/
.uv/
__pypackages__/

# ── Python 캐시 ──────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ── 빌드 / 배포 아티팩트 ─────────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ── 환경 변수 / 시크릿 ───────────────────────────────────
.env
.env.*
!.env.example

# ── 테스트 & 커버리지 ────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ── 데이터 파일 (sample_data.csv는 추적, 대용량 실제 데이터는 제외) ──
data/*.csv
!data/sample_data.csv

# ── IDE ──────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── macOS ────────────────────────────────────────────────
.DS_Store

# ── 로그 ─────────────────────────────────────────────────
*.log
